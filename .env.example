# Copy to .env and adjust as needed: `cp .env.example .env`
# docker compose automatically loads .env from the same directory.

# ---- Build ----
# Path to Dockerfile (relative to build context = repo root)
DOCKERFILE=examples/Dockerfile.with-agents

# Image tag to build/use
IMAGE=vscode-tunnel-claude:local

# ---- Tunnel ----
# Tunnel name shown in vscode.dev/tunnel/<name>
TUNNEL_NAME=my-tunnel

# Auth provider: github | microsoft
TUNNEL_PROVIDER=github

# Optional: pre-issued access token for headless boot (skips device-code flow).
# Leave unset to use interactive device-code auth on first run.
# VSCODE_CLI_ACCESS_TOKEN=

# ---- Workspace ----
# Host path mounted into the container at /workspace
WORKSPACE=.
