# Example: extend vscode-tunnel with Claude Code and Codex CLIs (native installers),
# the context-mode plugin for Claude Code, plus a general dev toolchain
# (gh, node, uv, jq, ripgrep, fzf, ...).
#
# Build:
#   docker build -f examples/Dockerfile.with-agents \
#     -t vscode-tunnel-agents:1.121.0 .
#
# Run (note the extra volumes for ~/.claude and ~/.codex state; the docker.sock
# mount is optional — only add it if you want Docker-outside-of-Docker):
#   docker run -d --name vscode-tunnel \
#     -v vscode-tunnel-state:/home/coder/.vscode-cli \
#     -v claude-code-state:/home/coder/.claude \
#     -v codex-state:/home/coder/.codex \
#     -v /var/run/docker.sock:/var/run/docker.sock \
#     -v "$PWD":/workspace \
#     vscode-tunnel-agents:1.121.0
#
# Inside the tunneled VS Code terminal:
#   claude /login      # one-time OAuth, persisted in the claude-code-state volume
#   codex login        # one-time OAuth, persisted in the codex-state volume
#   docker ps          # DooD: works WITHOUT sudo — entrypoint re-owns the socket
#
# Code intelligence (codebase-memory-mcp, pre-wired into claude/codex):
#   Say "Index this project" in claude/codex — graph lands in .codebase-memory/
#   Graph UI: forward port 9749 in VS Code, then open http://localhost:9749

ARG VSCODE_TUNNEL_IMAGE=ghcr.io/ch-courtesy/vscode-tunnel:latest
FROM ${VSCODE_TUNNEL_IMAGE}

USER root

# Use bash with pipefail so the `curl ... | bash` repo-setup pipes below fail
# loudly if the download breaks (default sh would mask curl's exit code).
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Dev toolchain. The runtime image ships ca-certificates + git but not curl,
# so we add curl/wget first (also needed by the native agent installers below),
# then the everyday CLI tools, sudo, gh (GitHub apt repo), Node.js LTS
# (NodeSource) and the Docker CLI (download.docker.com).
#
# Note on the agents: the claude/codex installers below drop standalone binaries
# and do NOT need Node at runtime. Node here is for general dev use (npm/npx,
# project tooling), not for the agents.
#
# Docker is "Docker-outside-of-Docker" (DooD): we install only the CLI +
# compose/buildx plugins (no dockerd). At runtime mount the host daemon socket
# (-v /var/run/docker.sock:/var/run/docker.sock). The mounted socket is owned by
# the host's docker group, which `coder` isn't in — so the dood-entrypoint added
# below re-owns it to the coder group at startup (one-time, via passwordless
# sudo), after which `docker ...` works WITHOUT a sudo prefix (also for tools
# like the VS Code Docker extension). Note: mounting the socket already grants
# host-root-equivalent access, so adding sudo here is not a meaningful extra
# exposure. Do NOT mount the socket if you don't want that.
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates curl wget gnupg sudo \
        gcc libc6-dev \
        jq ripgrep fzf less unzip zip; \
    # --- passwordless sudo for the coder user --- \
    echo 'coder ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/coder; \
    chmod 0440 /etc/sudoers.d/coder; \
    # --- GitHub CLI (gh): official apt repo + signed keyring --- \
    install -m 0755 -d /etc/apt/keyrings; \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        -o /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list; \
    # --- Docker CLI (DooD): official apt repo, CLI + plugins only (no daemon) --- \
    curl -fsSL https://download.docker.com/linux/debian/gpg \
        -o /etc/apt/keyrings/docker.asc; \
    chmod a+r /etc/apt/keyrings/docker.asc; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
        > /etc/apt/sources.list.d/docker.list; \
    # --- Node.js LTS: NodeSource repo (debian's nodejs is too old) --- \
    curl -fsSL https://deb.nodesource.com/setup_lts.x | bash -; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        gh nodejs \
        docker-ce-cli docker-compose-plugin docker-buildx-plugin; \
    rm -rf /var/lib/apt/lists/*

# yq (mikefarah, Go) — the `yq eval` flavor for YAML/JSON, NOT debian's python
# `yq`. Single static binary from GitHub releases, multi-arch. (No `--version`
# check here so emulated cross-arch builds don't need to exec the binary.)
RUN set -eux; \
    case "$(dpkg --print-architecture)" in \
      amd64) ya=amd64 ;; \
      arm64) ya=arm64 ;; \
      *) echo "unsupported arch: $(dpkg --print-architecture)" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://github.com/mikefarah/yq/releases/latest/download/yq_linux_${ya}" \
        -o /usr/local/bin/yq; \
    chmod 0755 /usr/local/bin/yq

# Seed agent + config state dirs with tight perms. Pre-creating these as coder
# matters for named volumes: Docker seeds an empty named volume from the image
# path on first use and preserves its ownership, so a coder-owned dir here keeps
# the mounted volume writable (otherwise it'd come up root-owned). ~/.config
# holds gh auth (and other tool config), hence 0700.
RUN install -d -m 0700 -o coder -g coder /home/coder/.claude \
 && install -d -m 0700 -o coder -g coder /home/coder/.codex \
 && install -d -m 0700 -o coder -g coder /home/coder/.config

# DooD bootstrap entrypoint (generated inline, no extra files). When the host
# docker socket is mounted, it re-owns the socket to the coder group via
# passwordless sudo so plain `docker ...` works, then kicks off the agent-state
# migration (below) in the background and execs the image's real tunnel
# entrypoint. A missing socket is fine — docker just won't connect.
RUN printf '%s\n' \
    '#!/usr/bin/env bash' \
    'set -euo pipefail' \
    'sock=/var/run/docker.sock' \
    'if [[ -S "$sock" ]]; then' \
    '  sudo chgrp coder "$sock" 2>/dev/null || true' \
    '  sudo chmod g+rw "$sock" 2>/dev/null || true' \
    'fi' \
    '/usr/local/bin/agent-state-migrate.sh >> "$HOME/.claude/agent-state-migrate.log" 2>&1 &' \
    'exec /usr/local/bin/entrypoint.sh "$@"' \
    > /usr/local/bin/dood-entrypoint.sh \
 && chmod 0755 /usr/local/bin/dood-entrypoint.sh

# Agent-state migration (generated inline, same style as above). The rtk hooks,
# Claude Code plugins and codex MCP wiring installed later in this file live in
# ~/.claude / ~/.codex. Docker only seeds those into a named volume when the
# volume is EMPTY on first mount — a pre-existing state volume (e.g. one created
# by an older image) masks whatever the new image baked in. This script re-checks
# each item at container start and re-applies only what's missing, so upgrading
# the image "just works" with existing volumes. Idempotent; network is only
# needed when something actually has to be (re)installed, and failures are
# logged (to ~/.claude/agent-state-migrate.log via the entrypoint) without
# blocking startup.
RUN printf '%s\n' \
    '#!/usr/bin/env bash' \
    'set -uo pipefail' \
    'export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"' \
    'log() { printf "[agent-state-migrate] %s\n" "$*"; }' \
    'log "start $(date -u +%Y-%m-%dT%H:%M:%SZ)"' \
    '# .claude.json lives in the volume via CLAUDE_CONFIG_DIR; a pre-existing' \
    '# volume masks the image copy, so seed it from the snapshot when missing' \
    'if [[ ! -f "$HOME/.claude/.claude.json" && -f /usr/local/share/claude-seed/claude.json ]]; then' \
    '  log "seeding .claude.json into claude-code-state volume"' \
    '  install -m 0600 /usr/local/share/claude-seed/claude.json "$HOME/.claude/.claude.json"' \
    'fi' \
    '# fold any legacy ~/.claude.json (tool that ignored CLAUDE_CONFIG_DIR)' \
    '# into the volume-backed file so it is not lost on recreation' \
    'if [[ -f "$HOME/.claude.json" ]]; then' \
    '  log "merging legacy ~/.claude.json into volume"' \
    '  if [[ -f "$HOME/.claude/.claude.json" ]]; then' \
    '    jq -s ".[0] * .[1]" "$HOME/.claude/.claude.json" "$HOME/.claude.json" > "$HOME/.claude/.claude.json.tmp" \' \
    '      && mv "$HOME/.claude/.claude.json.tmp" "$HOME/.claude/.claude.json" || log "WARN: legacy merge failed"' \
    '  else' \
    '    cp "$HOME/.claude.json" "$HOME/.claude/.claude.json"' \
    '  fi' \
    '  rm -f "$HOME/.claude.json"' \
    'fi' \
    '# rtk: hook for Claude Code + instructions for Codex' \
    'if command -v rtk >/dev/null 2>&1; then' \
    '  [[ -f "$HOME/.claude/RTK.md" ]] || { log "rtk: wiring Claude Code"; rtk init -g --auto-patch || log "WARN: rtk --auto-patch failed"; }' \
    '  [[ -f "$HOME/.codex/RTK.md" ]]  || { log "rtk: wiring Codex";       rtk init -g --codex      || log "WARN: rtk --codex failed"; }' \
    'fi' \
    '# Claude Code plugins (marketplace add is a no-op if already registered)' \
    'ensure_plugin() {' \
    '  grep -qs "\"$2\"" "$HOME/.claude/plugins/installed_plugins.json" && return 0' \
    '  log "plugin: installing $2"' \
    '  claude plugin marketplace add "$1" >/dev/null 2>&1 || true' \
    '  claude plugin install "$2" || log "WARN: plugin $2 install failed"' \
    '}' \
    'ensure_plugin mksglu/context-mode context-mode@context-mode' \
    'ensure_plugin JuliusBrussee/caveman caveman@caveman' \
    '# codebase-memory-mcp: codex-side wiring lives in the ~/.codex volume' \
    'if command -v codebase-memory-mcp >/dev/null 2>&1 && ! grep -qs "^\[mcp_servers\.codebase-memory-mcp\]" "$HOME/.codex/config.toml"; then' \
    '  log "codebase-memory-mcp: re-wiring agents"' \
    '  codebase-memory-mcp install -y || log "WARN: codebase-memory-mcp install failed"' \
    'fi' \
    'log "done"' \
    > /usr/local/bin/agent-state-migrate.sh \
 && chmod 0755 /usr/local/bin/agent-state-migrate.sh

# Install as the coder user so binaries land in /home/coder/.local/bin
# (both installers target $HOME/.local). Latest channel; background
# auto-updates stay enabled and write to the coder-owned ~/.local dirs.
# PATH is set here (not at the end) so later build steps can call the
# just-installed tools (cargo, rtk) without absolute paths; it also serves
# the tunneled terminal at runtime.
ENV HOME=/home/coder
ENV PATH=/home/coder/.local/bin:/home/coder/.cargo/bin:$PATH
# Keep Claude Code's top-level config (.claude.json — OAuth account, onboarding
# state, MCP wiring) inside ~/.claude so it lands in the claude-code-state
# volume. The default location is ~/.claude.json on the container filesystem,
# which is reset to the image's baked copy on every container recreation —
# wiping login state even though the token in ~/.claude/.credentials.json
# survives. With this env the file lives at ~/.claude/.claude.json instead.
ENV CLAUDE_CONFIG_DIR=/home/coder/.claude
USER coder
RUN curl -fsSL https://claude.ai/install.sh | bash

# Codex CLI: bypass install.sh (its SHA lookup is currently broken) and drop
# the standalone musl binary straight into ~/.local/bin. Multi-arch aware.
RUN set -eux; \
    arch="$(uname -m)"; \
    case "$arch" in \
      x86_64|amd64)  target="x86_64-unknown-linux-musl"  ;; \
      aarch64|arm64) target="aarch64-unknown-linux-musl" ;; \
      *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    mkdir -p "$HOME/.local/bin"; \
    curl -fsSL "https://github.com/openai/codex/releases/latest/download/codex-${target}.tar.gz" \
      | tar -xz -C "$HOME/.local/bin"; \
    mv "$HOME/.local/bin/codex-${target}" "$HOME/.local/bin/codex"; \
    chmod +x "$HOME/.local/bin/codex"

# uv (Astral): the modern Python toolchain — replaces pip/venv/virtualenv/pyenv/
# pipx, and installs standalone CPython on demand (`uv python install`). Lands in
# ~/.local/bin like the agents above; UV_NO_MODIFY_PATH skips shell-profile edits
# since PATH is set explicitly below. No system python3 needed.
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_NO_MODIFY_PATH=1 sh

# Rust toolchain (rustup, minimal profile): here for `cargo install <tool>`
# (e.g. rtk), not full Rust dev — rustc/cargo/rust-std only, no clippy/docs.
# gcc above provides the linker cargo needs. --no-modify-path skips
# shell-profile edits since PATH is set explicitly below (same as uv).
RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain stable --no-modify-path

# rtk (rtk-ai/rtk): CLI proxy that compresses command output (git/cargo/npm/
# grep/...) before it reaches the agent context window — 60-90% token savings.
# MUST be installed from git: the crates.io `rtk` is an unrelated project
# ("Rust Type Kit"). Built from source with the toolchain above; the binary
# lands in ~/.cargo/bin (already on PATH). Also symlinked into ~/.local/bin:
# tunneled sessions rebuild PATH from shell profiles, which keep ~/.local/bin
# but drop the image's ENV PATH (and with it ~/.cargo/bin) — without the
# symlink the rtk PreToolUse hook fails with "rtk: command not found".
RUN cargo install --git https://github.com/rtk-ai/rtk \
 && ln -s /home/coder/.cargo/bin/rtk /home/coder/.local/bin/rtk

# Wire rtk into both agents (non-interactive):
#  - Claude Code: --auto-patch registers a PreToolUse hook in
#    ~/.claude/settings.json (+ hook script and RTK.md) that transparently
#    rewrites Bash commands to their rtk equivalents.
#  - Codex: --codex adds RTK usage instructions to ~/.codex (AGENTS.md-style,
#    no hook mechanism there).
# These land in the ~/.claude / ~/.codex dirs that seed the named volumes on
# first use. NOTE: a pre-existing state volume masks this (also true for the
# codebase-memory-mcp files and plugins below) — the agent-state-migrate
# entrypoint hook above detects that at container start and re-applies it.
RUN rtk init -g --auto-patch \
 && rtk init -g --codex

# codebase-memory-mcp (DeusData): code-intelligence MCP server — indexes the
# repo into a persistent knowledge graph (158 languages, 14 MCP tools; graph
# lives in <repo>/.codebase-memory/). --ui picks the variant with the embedded
# 3D graph visualization. The installer drops a static binary in ~/.local/bin
# and runs `codebase-memory-mcp install -y`, which wires MCP entries for the
# agents detected above: Claude Code (.claude.json) and Codex (~/.codex —
# seeds the named volume; same masking caveat as rtk, auto-repaired at
# startup by agent-state-migrate).
# The graph UI auto-enables on the first MCP session and serves on
# 127.0.0.1:9749 — loopback only, so `docker -p` can't publish it; use
# VS Code port forwarding from the tunneled window instead.
RUN curl -fsSL https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/install.sh | bash -s -- --ui

# The installer above may not honor CLAUDE_CONFIG_DIR and write its Claude Code
# MCP wiring to the legacy ~/.claude.json path. Fold any such file into the
# volume-backed location so nothing configured at build time lives outside
# ~/.claude (later keys win on conflict — legacy file is the newer write here).
RUN if [ -f "$HOME/.claude.json" ]; then \
      if [ -f "$HOME/.claude/.claude.json" ]; then \
        jq -s '.[0] * .[1]' "$HOME/.claude/.claude.json" "$HOME/.claude.json" \
          > "$HOME/.claude/.claude.json.tmp" \
        && mv "$HOME/.claude/.claude.json.tmp" "$HOME/.claude/.claude.json"; \
      else \
        cp "$HOME/.claude.json" "$HOME/.claude/.claude.json"; \
      fi; \
      rm -f "$HOME/.claude.json"; \
    fi

# Use gh as git's credential helper for github.com, baked into coder's
# ~/.gitconfig at build time. --force lets this run unauthenticated (no login
# during build); it only writes the *helper directive*, pointing at the apt gh
# (/usr/bin/gh). The actual token lives in ~/.config/gh after `gh auth login`,
# which persists via the config volume — so git push/pull over HTTPS to github
# just works with no separate ~/.git-credentials file.
RUN gh auth setup-git --hostname github.com --force

# context-mode (mksglu/context-mode): Claude Code plugin that sandboxes tool
# output to save context-window tokens (MCP server + hooks + skills). Installed
# non-interactively via the plugin marketplace CLI; lands in ~/.claude (user
# scope), so it seeds the claude-code-state volume on first use. Same caveat
# as rtk above: a pre-existing state volume masks this — auto-repaired at
# startup by agent-state-migrate.
# The plugin's MCP server runs via the Node.js installed above.
RUN claude plugin marketplace add mksglu/context-mode \
 && claude plugin install context-mode@context-mode

# Claude Code plugin: caveman (compressed output mode, ~65% fewer output
# tokens). Registered/installed via the non-interactive `claude plugin` CLI —
# same effect as `/plugin marketplace add` + `/plugin install` in a session.
# Its hooks run via node (installed above). State lands in ~/.claude, so the
# same volume-masking caveat as rtk above applies — auto-repaired at startup
# by agent-state-migrate.
RUN claude plugin marketplace add JuliusBrussee/caveman \
 && claude plugin install caveman@caveman

# Snapshot the fully-wired .claude.json outside the volume mount path. A
# pre-existing claude-code-state volume masks ~/.claude at runtime, so
# agent-state-migrate seeds this copy into the volume when the file is missing
# there (fresh volumes get it via Docker's normal empty-volume seeding). Built
# unauthenticated, so it holds plugin/MCP config only — no secrets.
RUN sudo install -D -m 0644 -o root -g root \
      "$HOME/.claude/.claude.json" /usr/local/share/claude-seed/claude.json

# Override the base entrypoint with the DooD bootstrap; it fixes the docker
# socket perms (if mounted), runs the agent-state migration in the background,
# and then execs the original tunnel entrypoint. tini stays PID 1 for proper
# signal/zombie handling.
ENTRYPOINT ["/usr/bin/tini", "--", "/usr/local/bin/dood-entrypoint.sh"]
